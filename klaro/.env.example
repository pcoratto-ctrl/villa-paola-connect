# ---- Supabase ----
# Da: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role (SOLO lato server, mai esporre al client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Anthropic (commento AI) ----
ANTHROPIC_API_KEY=sk-ant-...
# Se ANTHROPIC_API_KEY manca o non è valida, mostra un commento dimostrativo
# locale (chiaramente etichettato come bozza, mai spacciato per output AI)
# invece di bloccare il flusso. Attivo di default in sviluppo (next dev);
# fuori da development serve impostarlo esplicitamente a "true".
ENABLE_AI_DEMO_FALLBACK=false

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ID dei prezzi ricorrenti creati in Stripe (mensili)
STRIPE_PRICE_STARTER=price_...   # €19/mese - fino a 5 clienti
STRIPE_PRICE_PRO=price_...       # €39/mese - fino a 20 clienti

# ---- App ----
# URL pubblico dell'app (per redirect Stripe). In locale: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Beta privata ----
# Email autorizzate ad accedere (minuscole, separate da virgola). Se vuota o
# assente, l'app NON blocca nessuno (comportamento normale, non-beta). Va
# tenuta sincronizzata "a mano" con la tabella public.beta_allowed_emails
# popolata da supabase/migrations/002_beta_privata.sql (quella è l'ultima
# barriera non aggirabile lato database; questa è il controllo lato app).
# NON prefissarla con NEXT_PUBLIC_: non deve mai arrivare al browser.
BETA_ALLOWED_EMAILS=tester1@esempio.it,tester2@esempio.it

# URL a cui punta il pulsante "Invia feedback" (form esterno, Slack, ecc.).
# Se assente, il pulsante apre un mailto: semplice senza destinatario preimpostato.
NEXT_PUBLIC_FEEDBACK_URL=
