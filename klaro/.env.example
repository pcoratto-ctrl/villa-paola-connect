# ---- Supabase ----
# Da: Supabase Dashboard -> Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
# Service role (SOLO lato server, mai esporre al client)
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ---- Anthropic (commento AI) ----
ANTHROPIC_API_KEY=sk-ant-...
# Se ANTHROPIC_API_KEY manca o non è valida, mostra un commento dimostrativo
# locale (chiaramente etichettato come bozza, mai spacciato per output AI)
# invece di bloccare il flusso. Attivo di default in sviluppo (next dev);
# fuori da development serve impostarlo esplicitamente a "true".
ENABLE_AI_DEMO_FALLBACK=false

# ---- Stripe ----
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# ID dei prezzi ricorrenti creati in Stripe (mensili)
STRIPE_PRICE_STARTER=price_...   # €19/mese - fino a 5 clienti
STRIPE_PRICE_PRO=price_...       # €39/mese - fino a 20 clienti

# ---- App ----
# URL pubblico dell'app (per redirect Stripe). In locale: http://localhost:3000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Beta privata ----
# Email autorizzate ad accedere (minuscole, separate da virgola). Se vuota o
# assente, l'app NON blocca nessuno (comportamento normale, non-beta). Va
# tenuta sincronizzata "a mano" con la tabella public.beta_allowed_emails
# su Supabase (vedi supabase/README.md) — quella è l'ultima barriera non
# aggirabile lato database (Before User Created Hook + trigger); questa è
# solo il controllo rapido lato app. NON prefissarla con NEXT_PUBLIC_: non
# deve mai arrivare al browser.
BETA_ALLOWED_EMAILS=tester1@esempio.it,tester2@esempio.it

# URL a cui punta il pulsante feedback (form esterno, Slack, ecc.). Se
# assente, il pulsante apre un mailto: verso NEXT_PUBLIC_SUPPORT_EMAIL.
NEXT_PUBLIC_FEEDBACK_URL=

# Nome mostrato nei testi "personali" della beta (email, pagina di
# benvenuto, messaggi di contatto). Default "Pierpaolo" se assente.
NEXT_PUBLIC_FOUNDER_NAME=Pierpaolo

# Email di supporto per i mailto: (fallback di NEXT_PUBLIC_FEEDBACK_URL e
# contatti nei messaggi di errore). Pubblica per design: non è un segreto,
# ma è comunque un indirizzo personale, quindi va impostata via env var e
# mai scritta a mano nei componenti.
NEXT_PUBLIC_SUPPORT_EMAIL=
